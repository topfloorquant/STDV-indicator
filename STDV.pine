//@version=6
indicator("Sigma Distribution Bands", overlay = true, max_labels_count = 20)

// ── Inputs
length     = input.int(100, "Lookback Length", minval = 1)
src        = input.source(close, "Source")
showLabels = input.bool(true, "Show Probability Labels")

// ── Mean & Standard Deviation
mu  = ta.sma(src, length)
sig = ta.stdev(src, length)

// ── Sigma Levels
p3 = mu + 3.0 * sig
p2 = mu + 2.0 * sig
p1 = mu + 1.0 * sig
m0 = mu
n1 = mu - 1.0 * sig
n2 = mu - 2.0 * sig
n3 = mu - 3.0 * sig

// ── Plots (SOLID — supported)
plot(p3, title="+3σ", color=color.red,  linewidth=1)
plot(p2, title="+2σ", color=color.red,  linewidth=1)
plot(p1, title="+1σ", color=color.red,  linewidth=2)

plot(m0, title="0σ",  color=color.blue, linewidth=2)

plot(n1, title="-1σ", color=color.teal, linewidth=2)
plot(n2, title="-2σ", color=color.teal, linewidth=1)
plot(n3, title="-3σ", color=color.teal, linewidth=1)

// ── Labels (last bar only)
if showLabels and barstate.islast
    label.new(bar_index + 2, p3, "0.14% (+3σ)",  style=label.style_none, textcolor=color.rgb(255, 255, 255))
    label.new(bar_index + 2, p2, "2.27% (+2σ)",  style=label.style_none, textcolor=color.rgb(255, 255, 255))
    label.new(bar_index + 2, p1, "15.87% (+1σ)", style=label.style_none, textcolor=color.rgb(255, 255, 255))

    label.new(bar_index + 2, m0, "50% (0σ)",     style=label.style_none, textcolor=color.rgb(255, 255, 255))

    label.new(bar_index + 2, n1, "15.87% (-1σ)", style=label.style_none, textcolor=color.rgb(255, 255, 255))
    label.new(bar_index + 2, n2, "2.27% (-2σ)",  style=label.style_none, textcolor=color.rgb(255, 255, 255))
    label.new(bar_index + 2, n3, "0.14% (-3σ)",  style=label.style_none, textcolor=color.rgb(255, 255, 255))
